### =========================
### Health Check
### =========================
GET http://localhost:8080/health


### =========================
### 1. Ingest Sample Doc
### =========================
POST http://localhost:8080/api/ingest
Content-Type: application/json

{
  "docId": "spring-doc",
  "content": "Spring Boot exception handling can be done using @ControllerAdvice and @ExceptionHandler. It helps centralize error handling across controllers."
}


### =========================
### 2. Ask + Email Flow
### =========================
POST http://localhost:8080/agent
Content-Type: application/json

{
  "prompt": "Explain Spring Boot exception handling and email it to hr@company.com",
  "docId": "spring-doc"
}

> {%
    // 🔥 capture sessionId from response
    client.global.set("sessionId", response.body.sessionId);
%}


### =========================
### 3. Continue → Shorten Email
### =========================
POST http://localhost:8080/agent/continue
Content-Type: application/json

{
  "sessionId": "{{sessionId}}",
  "instruction": "shorten it"
}


### =========================
### 4. Continue → Send Email
### =========================
POST http://localhost:8080/agent/continue
Content-Type: application/json

{
  "sessionId": "{{sessionId}}",
  "instruction": "send it"
}


### =========================
### 5. Ask + SMS Flow
### =========================
POST http://localhost:8080/agent
Content-Type: application/json

{
  "prompt": "Explain Spring Boot exception handling and text it to me",
  "docId": "spring-doc"
}


> {%
    // 🔥 capture sessionId from response
    client.global.set("sessionId", response.body.sessionId);
%}

### =========================
### 6. Continue → Send SMS
### =========================
POST http://localhost:8080/agent/continue
Content-Type: application/json

{
  "sessionId": "{{sessionId}}",
  "instruction": "send sms"
}

###
###
GET http://localhost:8080/agent/{{sessionId}}
Content-Type: application/json

### =========================
### 7. Direct SMS (No Research)
### =========================
POST http://localhost:8080/agent
Content-Type: application/json

{
  "prompt": "Text hello this is a test message",
  "docId": "spring-doc"
}


### =========================
### 8. Get Session State
### =========================
GET http://localhost:8080/agent/PUT_SESSION_ID_HERE