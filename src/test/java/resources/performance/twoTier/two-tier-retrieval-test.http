%}

###


### ── Phase 2: Verify summaries populated ──────────────────────────────

### 2.1 List all vehicle summaries
### Expected: one row per ingested vehicle with hasEmbedding=true
GET http://localhost:8080/vehicles/admin/summaries
Content-Type: application/json

> {%
    client.log("Summaries: " + response.body?.length);
    response.body?.forEach(s => {
        client.log("  " + s.vehicleId + " - " + s.chunkCount + " chunks, embedding=" + s.hasEmbedding);
    });
%}

###


### ── Phase 3: Two-tier fleet search ───────────────────────────────────
### 3.1 Fleet search - performance query
### Expected: BMW M3 ranks higher than Tesla on performance
### Check: tier1Ms (summary search) + totalMs (end-to-end)
POST http://localhost:8080/vehicles/ask/fleet
Content-Type: application/json

{
  "question": "Which vehicle has the best performance?",
  "topK": 5
}

> {%
    client.log("=== TWO-TIER RESULTS ===");
    client.log("Tier 1 (summaries): " + response.body.tier1Ms + "ms");
    client.log("Total: " + response.body.totalMs + "ms");
    client.log("Candidates: " + response.body.candidates?.length);
    response.body.candidates?.forEach(c => {
        client.log("  " + c.vehicleName + " (score=" + c.score?.toFixed(3) + ")");
    });
    client.log("Detail results: " + response.body.results?.length);
    response.body.results?.forEach(r => {
        client.log("  #" + r.rank + " " + r.vehicleId + " - " + r.excerpt?.substring(0, 80));
    });
%}

###

### 3.2 Fleet search - fuel economy query
### Expected: Tesla Model 3 ranks higher (134 MPGe vs 16 MPG)
POST http://localhost:8080/vehicles/ask/fleet
Content-Type: application/json

{
  "question": "Which vehicle has the best fuel economy?",
  "topK": 5
}

> {%
    client.log("Tier 1: " + response.body.tier1Ms + "ms, Total: " + response.body.totalMs + "ms");
    response.body.candidates?.forEach(c => {
        client.log("  " + c.vehicleName + " (score=" + c.score?.toFixed(3) + ")");
    });
%}

###

### 3.3 Fleet search - value query
### Expected: Tesla Model 3 ranks higher ($47,990 vs $76,900)
POST http://localhost:8080/vehicles/ask/fleet
Content-Type: application/json

{
  "question": "Which car offers the best value for money?",
  "topK": 5
}

> {%
    client.log("Tier 1: " + response.body.tier1Ms + "ms, Total: " + response.body.totalMs + "ms");
%}

