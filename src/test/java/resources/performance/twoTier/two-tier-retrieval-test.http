### ── Phase 7: Bulk ingestion ──────────────────────────────────────────

### 7.1 Bulk ingest 3 vehicles at once
POST http://localhost:8080/vehicles/ingest/bulk
Content-Type: application/json

[
  {
    "vehicleId": "porsche-911-2025-carrera-s",
    "year": 2025, "make": "Porsche", "model": "911", "trim": "Carrera S",
    "bodyStyle": "Coupe", "vehicleClass": "sports car",
    "engine": "3.0L twin-turbo flat-6", "horsepower": 443, "torque": 390,
    "drivetrain": "RWD", "transmission": "8-speed PDK",
    "zeroToSixty": 3.3, "topSpeed": 191,
    "mpgCity": "18", "mpgHighway": "25", "msrp": "$120,100",
    "fuelType": "Premium gasoline",
    "features": ["sport chrono package", "PASM", "Bose surround sound"],
    "reviews": [
      {"source": "Car and Driver", "year": 2025, "score": 10, "summary": "The benchmark sports car, period."}
    ]
  },
  {
    "vehicleId": "ford-f150-2025-lariat",
    "year": 2025, "make": "Ford", "model": "F-150", "trim": "Lariat",
    "bodyStyle": "Pickup Truck", "vehicleClass": "full-size truck",
    "engine": "3.5L EcoBoost V6", "horsepower": 400, "torque": 500,
    "drivetrain": "4WD", "transmission": "10-speed automatic",
    "mpgCity": "18", "mpgHighway": "24", "msrp": "$52,430",
    "fuelType": "Regular gasoline",
    "features": ["pro power onboard", "360-degree camera", "trailer brake controller"],
    "reviews": [
      {"source": "Motor Trend", "year": 2025, "score": 8, "summary": "Still the best-selling truck for a reason."}
    ]
  },
  {
    "vehicleId": "honda-crv-2025-sport-hybrid",
    "year": 2025, "make": "Honda", "model": "CR-V", "trim": "Sport Hybrid",
    "bodyStyle": "SUV", "vehicleClass": "compact SUV",
    "engine": "2.0L Atkinson-cycle i-VTEC + electric motor", "horsepower": 204, "torque": 247,
    "drivetrain": "AWD", "transmission": "CVT",
    "mpgCity": "40", "mpgHighway": "34", "msrp": "$36,100",
    "fuelType": "Regular gasoline",
    "features": ["Honda Sensing suite", "wireless Apple CarPlay", "heated seats"],
    "reviews": [
      {"source": "Consumer Reports", "year": 2025, "score": 9, "summary": "The most practical compact SUV you can buy."}
    ]
  }
]

> {%
    client.log("=== BULK INGEST ===");
    client.log("Vehicles: " + response.body.totalVehicles);
    client.log("Chunks: " + response.body.totalChunks);
    client.log("Summaries: " + response.body.totalSummaries);
    client.log("Elapsed: " + response.body.elapsedMs + "ms");
    client.log("Errors: " + response.body.errors?.length);
%}

###

### 7.2 Verify summaries after bulk ingest
### Expected: 5 vehicles total (BMW, Tesla, Porsche, Ford, Honda)
GET http://localhost:8080/vehicles/admin/summaries
Content-Type: application/json

> {%
    client.log("Total summaries: " + response.body?.length);
    response.body?.forEach(s => {
        client.log("  " + s.year + " " + s.make + " " + s.model + " " + s.trim + " - " + s.chunkCount + " chunks");
    });
%}

###

### 7.3 Fleet search after bulk ingest - should now find 5 vehicles
POST http://localhost:8080/vehicles/ask/fleet
Content-Type: application/json

{
  "question": "Compare all available vehicles by price and performance",
  "topK": 10
}

> {%
    client.log("Candidates: " + response.body.candidates?.length);
    client.log("Tier 1: " + response.body.tier1Ms + "ms, Total: " + response.body.totalMs + "ms");
    response.body.candidates?.forEach(c => {
        client.log("  " + c.vehicleName + " (score=" + c.score?.toFixed(3) + ")");
    });
%}

